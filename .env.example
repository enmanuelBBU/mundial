# ─── API de fútbol (resultados) ───
# Consíguela gratis en: https://www.football-data.org/client/register
FOOTBALL_API_KEY=TU_API_KEY_AQUI

# ─── Apuestas + login (Supabase) — OPCIONAL ───
# Si no las pones, la app funciona igual pero sin la sección de apuestas.
# Crea un proyecto gratis en https://supabase.com y copia estos valores.
SUPABASE_URL=https://TU-PROYECTO.supabase.co
# Settings → API → Project API keys → service_role (¡es secreta!, solo servidor)
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY
# Secreto para firmar la cookie de sesión. Pon una cadena aleatoria larga.
SESSION_SECRET=pon_aqui_algo_aleatorio_y_largo
